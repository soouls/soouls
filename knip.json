{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["apps/*/src/**/*.{ts,tsx}", "packages/*/src/**/*.{ts,tsx}"],
  "project": ["apps/*/package.json", "packages/*/package.json"],
  "ignore": [
    "**/dist/**",
    "**/.next/**",
    "**/node_modules/**",
    "**/*.config.{js,ts}",
    "**/drizzle.config.ts"
  ],
  "ignoreDependencies": ["@soulcanvas/*"]
}
